generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PageRoute {
  id                 String      @id @default(cuid())
  host               String
  path               String
  defaultTemplateKey String
  defaultConfig      Json?
  isArchived         Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  events             Event[]
  experiment         Experiment?

  @@unique([host, path])
  @@index([host, path])
}

model Experiment {
  id          String                 @id @default(cuid())
  name        String
  state       ExperimentState        @default(DRAFT)
  assignmentMode AssignmentMode      @default(STICKY)
  routingMode    RoutingMode         @default(REWRITE)
  routeId     String                 @unique
  startedAt   DateTime?
  pausedAt    DateTime?
  archivedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  events      Event[]
  route       PageRoute              @relation(fields: [routeId], references: [id])
  assignments ExperimentAssignment[]
  variants    Variant[]

  @@index([state])
}

model Variant {
  id             String                 @id @default(cuid())
  experimentId   String
  key            String
  name           String
  weightPercent  Int
  isControl      Boolean                @default(false)
  templateKey    String
  templateConfig Json?
  redirectPath   String?
  redirectUrl    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  events         Event[]
  assignments    ExperimentAssignment[]
  experiment     Experiment             @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, key])
  @@index([experimentId])
}

model ExperimentAssignment {
  id           String     @id @default(cuid())
  experimentId String
  visitorId    String
  variantId    String
  assignedAt   DateTime   @default(now())
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant      Variant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  visitor      Visitor    @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@unique([experimentId, visitorId])
  @@index([visitorId, assignedAt])
}

model Visitor {
  id          String                 @id
  firstSeenAt DateTime               @default(now())
  lastSeenAt  DateTime               @default(now())
  events      Event[]
  assignments ExperimentAssignment[]
  sessions    LpSession[]
}

model LpSession {
  id              String   @id
  visitorId       String
  startedAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  landingUrl      String?
  initialReferrer String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  gbraid          String?
  wbraid          String?
  events          Event[]
  visitor         Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([visitorId])
  @@index([startedAt])
}

model Event {
  id           String      @id @default(cuid())
  type         EventType
  occurredAt   DateTime    @default(now())
  properties   Json?
  pageRouteId  String
  experimentId String?
  variantId    String?
  visitorId    String
  sessionId    String
  conversion   Conversion?
  experiment   Experiment? @relation(fields: [experimentId], references: [id])
  pageRoute    PageRoute   @relation(fields: [pageRouteId], references: [id])
  session      LpSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant      Variant?    @relation(fields: [variantId], references: [id])
  visitor      Visitor     @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@index([pageRouteId, occurredAt])
  @@index([experimentId, variantId, occurredAt])
  @@index([visitorId, sessionId, occurredAt])
}

model Conversion {
  id             String   @id @default(cuid())
  eventId        String   @unique
  conversionType String
  value          Float?
  dedupeKey      String
  createdAt      DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([conversionType, createdAt])
  @@index([dedupeKey])
}

model IntegrationConfig {
  id               Int      @id @default(1)
  gtmContainerId   String?
  ga4MeasurementId String?
  hotjarSiteId     String?
  ghlWebhookUrl    String?
  ghlWebhookSecret String?
  updatedAt        DateTime @updatedAt
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  provider      String
  eventId       String
  dedupeKey     String
  payload       Json
  status        String    @default("PENDING")
  attemptCount  Int       @default(0)
  nextAttemptAt DateTime  @default(now())
  lastError     String?
  lastStatus    Int?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([provider, status, nextAttemptAt])
  @@index([dedupeKey])
  @@index([eventId])
}

enum ExperimentState {
  DRAFT
  RUNNING
  PAUSED
  ARCHIVED
}

enum AssignmentMode {
  TESTING
  STICKY
}

enum RoutingMode {
  REWRITE
  REDIRECT
}

enum EventType {
  page_view
  cta_click
  lead_submit
  conversion
}
